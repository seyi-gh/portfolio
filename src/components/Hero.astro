---
// src/components/Hero.astro
import FadeIn from './FadeIn.tsx';
---

<section class="min-h-screen flex items-center relative overflow-hidden pt-24">
  <div class="absolute inset-0 z-0 opacity-20 pointer-events-none flex items-center justify-center">
    <div class="absolute inset-0 bg-gradient-to-b from-background/50 to-background z-10"></div>
  </div>

  <div class="max-w-[1280px] mx-auto px-8 w-full z-10 grid grid-cols-1 md:grid-cols-12 gap-8">
    <div class="md:col-span-10 lg:col-span-8 flex flex-col gap-8">
      
      <!-- 'client:load' for inmediately animation in load of the page -->
      <FadeIn client:load direction="up" delay={0.1}>
        <h1 class="font-display text-5xl md:text-[80px] leading-tight font-bold text-white mb-2 tracking-tighter">
          AESIO CHU.
        </h1>
        <h2 class="font-display text-3xl md:text-[48px] leading-tight font-semibold text-primary-container">
          FULL STACK DEVELOPER
        </h2>
      </FadeIn>
      
      <FadeIn client:load direction="up" delay={0.3}>
        <p class="font-sans text-lg text-gray-400 max-w-2xl leading-relaxed">
          Arquitecto de experiencias digitales con precisión. Especializado en aplicaciones web de alto rendimiento y diseño de interfaces UX/UI, utilizando un enfoque técnico minimalista para crear soluciones escalables.
        </p>
      </FadeIn>
      
      <FadeIn client:load direction="up" delay={0.5}>
        <div class="flex flex-wrap gap-4 mt-4">
          <a class="inline-flex items-center justify-center px-8 py-4 bg-primary-container text-white font-semibold rounded-lg text-sm uppercase hover:bg-surface transition-colors border border-gray-600 hover:border-gray-400" href="#work">
            Ver Proyectos
          </a>
          <a class="inline-flex items-center justify-center px-8 py-4 bg-primary-container text-white font-semibold rounded-lg text-sm uppercase hover:bg-surface transition-colors border border-gray-600 hover:border-gray-400" href="#contact">
            Contacto
          </a>
        </div>
      </FadeIn>

    </div>
  </div>
</section>